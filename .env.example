# ============================================================================
# OPS AI Runbook Assistant - Configuration Template
# ============================================================================
# Copy this file to .env and customize for your environment
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================

# Application name displayed in API docs and logs
APP_NAME=OPS AI Runbook Assistant

# Semantic version (MAJOR.MINOR.PATCH)
APP_VERSION=0.1.0

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Detailed diagnostic information (development)
# INFO: Confirmation that things work as expected (default)
# WARNING: Something unexpected happened
# ERROR: Serious problem, function failed
# CRITICAL: Very serious error, program might fail
LOG_LEVEL=INFO

# ============================================================================
# Ollama LLM Configuration
# ============================================================================

# Base URL for Ollama API
# Local development: http://localhost:11434
# Docker network: http://ollama:11434
# Remote: https://ollama.example.com
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# Server Configuration
# ============================================================================

# Server binding address
# 0.0.0.0: Listen on all network interfaces (Docker friendly)
# 127.0.0.1: Listen only on localhost (local development)
# 192.168.x.x: Bind to specific interface
HOST=0.0.0.0

# Server listening port
# FastAPI: 8000 (default)
# Standard HTTP: 80 (requires root/sudo)
# Standard HTTPS: 443 (requires root/sudo)
PORT=8000

# ============================================================================
# Performance Tuning
# ============================================================================

# LLM request timeout in seconds (default: 300)
# Increase if getting timeout errors on slow systems
LLM_REQUEST_TIMEOUT=300

# Maximum retries for LLM requests on timeout (default: 2)
LLM_MAX_RETRIES=2

# Top-K documents to retrieve from vector DB (default: 3)
RAG_TOP_K=3

# ============================================================================
# Notes
# ============================================================================

# Docker Compose users:
# Set OLLAMA_BASE_URL=http://ollama:11434 (service name, not localhost)
# Set HOST=0.0.0.0 for container networking

# Production deployment:
# Set LOG_LEVEL=WARNING to reduce log volume
# Use environment secrets for sensitive data
# Set HOST to internal IP if behind reverse proxy
# Configure rate limiting at reverse proxy level